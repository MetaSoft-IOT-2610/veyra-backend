@startuml Veyra_Platform_Deployment

skinparam BackgroundColor           #ffffff
skinparam CanvasBorderColor         #ffffff
skinparam ArrowColor                #334155
skinparam ArrowFontColor            #475569
skinparam ArrowFontSize             10
skinparam ArrowThickness            1.5
skinparam ArrowFontStyle            italic
skinparam DefaultFontName           "Segoe UI"
skinparam DefaultFontSize           12
skinparam DefaultFontColor          #1e293b
skinparam Shadowing                 false
skinparam linetype                  ortho

skinparam rectangle {
  BorderThickness  2
  RoundCorner      10
  BorderColor      #3b82f6
  BackgroundColor  #dbeafe
  FontColor        #1e293b
}

skinparam database {
  BorderColor      #16a34a
  BackgroundColor  #dcfce7
  FontColor        #14532d
}

skinparam frame {
  BorderColor      #94a3b8
  BackgroundColor  #f1f5f9
  FontColor        #1e293b
}

skinparam note {
  BorderColor      #cbd5e1
  BackgroundColor  #f8fafc
  FontColor        #475569
  FontSize         10
}

title
<size:22><b><color:#1e293b>Veyra Platform</color></b></size>
<size:13><color:#3b82f6>Production Deployment Architecture</color></size>
<size:10><color:#94a3b8>C4 Model - Deployment View</color></size>
end title

' ── GITHUB PAGES ──────────────────────────────────────────────────
frame "GitHub Pages - Static Hosting" as githubPages {
  rectangle "**Landing Page**\nHTML, CSS, JavaScript\nPublic website and registration" as landingPage
}

' ── GOOGLE FIREBASE ───────────────────────────────────────────────
frame "Google Firebase - Web and Mobile Platform" as firebase {

  frame "Firebase Hosting - Web Hosting" as firebaseHosting {
    rectangle "**Web Application**\nNginx\nDelivers Angular SPA to browser" as webApplication
    rectangle "**Veyra Web Client App**\nTypeScript, Angular\nUsed by doctors, nurses, admins, relatives" as webClientApp
  }

  frame "Firebase App Distribution - Mobile Delivery" as firebaseDistribution {
    rectangle "**Veyra Mobile App**\nFlutter, Dart\nReal-time resident monitoring" as mobileApp
  }
}

' ── MICROSOFT AZURE ───────────────────────────────────────────────
frame "Microsoft Azure - Cloud Platform" as azure {

  frame "Azure Region - East US" as azureRegion {

    frame "Azure App Service - Backend Hosting" as azureAppService {
      rectangle "**Veyra API Application**\nJava, Spring Boot\nREST API and Business Logic" as monolithBackend
    }

    frame "Azure Database for MySQL" as azureMySQL {
      database "**MySQL Database**\nMySQL 8.0\nUsers, residents, care records, subscriptions" as mysqlDB
    }

    frame "Azure Cosmos DB - Document Database" as azureCosmos {
      database "**MongoDB Database**\nMongoDB API\nIoT telemetry, vital signs, GPS history" as mongoDB
    }
  }
}

' ── ON-PREMISES ───────────────────────────────────────────────────
frame "On-Premises - Nursing Home" as onPremises {

  frame "Edge Server - Raspberry Pi 5, Ubuntu 24.04" as edgeServer {
    rectangle "**Vital Signs Edge App**\nPython\nProcesses vital signs locally" as edgeApp
    rectangle "**GPS Edge App**\nPython\nProcesses GPS telemetry locally" as edgeAppB
  }

  frame "Vital Signs IoT Device - Embedded Hardware" as iotVital {
    rectangle "**Vital Signs Embedded App**\nC++\nAcquires raw vital signs from sensors" as embeddedApp
  }

  frame "GPS Tracker Device - Embedded Hardware" as iotGPS {
    rectangle "**GPS Embedded App**\nC++\nAcquires raw location from GPS hardware" as embeddedAppB
  }
}

' ── RELATIONSHIPS ─────────────────────────────────────────────────
landingPage     -down->  webApplication  : Delegates SPA bundle delivery\n**HTTP**
webApplication  -down->  webClientApp    : Delivers SPA bundle to browser\n**HTTP**
webClientApp    -down->  monolithBackend : Invokes REST API endpoints\n**HTTPS, JWT**
mobileApp       -down->  monolithBackend : Invokes REST API endpoints\n**HTTPS, JWT**
monolithBackend -right-> mysqlDB         : Persists and queries relational data\n**JDBC, JPA**
monolithBackend -right-> mongoDB         : Persists and queries IoT telemetry\n**MongoDB Driver**
embeddedApp     -up->    edgeApp         : Streams raw vital signs data\n**Local TCP**
embeddedAppB    -up->    edgeAppB        : Streams raw GPS data\n**Local TCP**
edgeApp         -up->    monolithBackend : Forwards vital signs and alerts\n**HTTPS, mTLS**
edgeAppB        -up->    monolithBackend : Forwards GPS data and geofence events\n**HTTPS, mTLS**
webClientApp    -down->  edgeApp         : Issues vital signs monitoring commands\n**HTTPS, JWT**
webClientApp    -down->  edgeAppB        : Issues GPS tracking commands\n**HTTPS, JWT**

@enduml